{% comment %} 
            This section is used in the product template to render product page with
            media, content, and add-to-cart form.
            
            https://shopify.dev/docs/storefronts/themes/architecture/templates/product 
{% endcomment %}
{{ 'product-variant-picker.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign current_media = current_variant.featured_media | default: product.featured_media -%}

<div class="product section-{{ section.id }}" data-product-root>
  <div class="product-page__layout">
    <div class="product-page__media">
      <div
        class="product-gallery"
        data-product-gallery
        role="region"
        aria-label="Product media gallery">
        <div class="product-gallery__main">
          {%- if current_media -%}
            <img
              class="product-gallery__main-image"
              data-product-image
              src="{{ current_media.preview_image | image_url: width: 1200 }}"
              alt="{{ current_media.alt | default: product.title | escape }}"
              width="{{ current_media.preview_image.width }}"
              height="{{ current_media.preview_image.height }}"
              loading="eager">
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbnails" aria-lable="Product thumbnails">
            {%- for media in product.media -%}
              {%- assign thumbnail_image = media.preview_image -%}
              <button
                class="product-gallery__thumbnail{% if current_media and media.id == current_media.id %} product-gallery__thumbnail--active{% endif %}"
                type="button"
                aria-label="Show product image {{ forloop.index }}"
                aria-current="{% if current_media and media.id == current_media.id %}true{% else %}false{% endif %}"
                data-product-thumbnail
                data-media-id="{{ media.id }}"
                data-media-src="{{ thumbnail_image | image_url: width: 1200 }}"
                data-media-alt="{{ media.alt | default: product.title | escape }}">
                <img
                  src="{{ thumbnail_image | image_url: width: 160 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="{{ thumbnail_image.width }}"
                  height="{{ thumbnail_image.height }}"
                  loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="product-info">
      <div class="product-page__header">
        <h1 class="product-page__title">{{ product.title }}</h1>

        <div class="product-page__pricing">
          <p class="product-page__price" data-product-price>
            {{ current_variant.price | money }}
          </p>

          <p class="product-page__compare-price{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}" data-product-compare-price>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              {{ current_variant.compare_at_price | money }}
            {%- endif -%}
          </p>
        </div>

        <p class="product-page__status" data-product-status>
          {%- if current_variant.available -%}
            In stock
          {% else %}
            Sold out
          {%- endif -%}
        </p>
      </div>

      <div class="product-page__description rte">
        {{ product.description }}
      </div>

      <div class="product-page__form">
        {% form 'product'
          , product %}

          {%- render 'product-variant-picker'
            , product: product
            , section: section -%}

          <div class="product-page__quantity">
            <label for="Quantity-{{ section.id }}" class="product-page__quantity-label">
              Quantity
            </label>
            <input
              id="Quantity-{{ section.id }}"
              class="product-page__quantity-input"
              type="number"
              name="quantity"
              min="1"
              value="1">
          </div>

          <button
            class="product-page__add-to-cart"
            type="submit"
            data-add-to-cart
            {%- unless current_variant.available -%}
            disabled{%- endunless -%}>
            {% if current_variant.available %}
              Add to cart
            {% else %}
              Sold out
            {% endif %}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'product-gallery.js' | asset_url }}" defer></script>
<script src="{{  'product-variant-picker.js' | asset_url }}" defer></script>

{% schema %}
  {
    "name": "t:general.product",
    "settings": [],
    "disabled_on": {
      "groups": ["header", "footer"]
    }
  }
{% endschema %}