{{ 'featured-collection.css' | asset_url | stylesheet_tag }}

{% assign collection = section.settings.collection %}

<section
  class="featured-collection section-{{ section.id }}"
  role="region"
  aria-label="{{ section.settings.heading | escape }}">
  <div class="featured-collection__header">
    {% if section.settings.heading != blank %}
      <h2 class="featured-collection__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
  </div>
  {% if collection == blank %}
    <p class="featured-collection__empty">
      Select a collection in the Theme Editor to display products.
    </p>
  {% else %}
    <div class="featured-collection__grid" style="
      --fc-columns: {{ section.settings.columns }};
      --fc-columns-mobile: {{ section.settings.columns_mobile }};
      --card-ratio: {{ section.settings.image_ratio }};
    ">
      {% for product in collection.products limit: section.settings.products_to_show %}
        {% render 'product-card'
          , product: product %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
  {
    "name": "Featured Collection Grid",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured collection"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "range",
        "id": "products_to_show",
        "label": "Products to show",
        "min": 2,
        "max": 12,
        "step": 1,
        "default": 4
      },
      {
        "type": "select",
        "id": "columns",
        "label": "Columns (desktop)",
        "default": "4",
        "options": [
          {
            "value": "2",
            "label": "2"
          }, {
            "value": "3",
            "label": "3"
          }, {
            "value": "4",
            "label": "4"
          }
        ]
      }, {
        "type": "select",
        "id": "image_ratio",
        "label": "Image ratio",
        "default": "1 / 1",
        "options": [
          {
            "value": "1 / 1",
            "label": "Square"
          }, {
            "value": "3 / 4",
            "label": "Portrait"
          }, {
            "value": "4 / 3",
            "label": "Landscape"
          }
        ]
      }, {
        "type": "select",
        "id": "columns_mobile",
        "label": "Columns (mobile)",
        "default": "2",
        "options": [
          {
            "value": "1",
            "label": "1"
          }, {
            "value": "2",
            "label": "2"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Featured Collection Grid"
      }
    ]
  }
{% endschema %}